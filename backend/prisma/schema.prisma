// WHY Prisma at all: we get typed CRUD for the boring parts (documents, chunks)
// and migrations, while still being able to drop to raw SQL for the one thing
// Prisma can't type: pgvector similarity queries.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  // Runtime traffic goes through Supabase's connection pooler (port 6543).
  // WHY: serverless/long-running apps can exhaust Postgres's direct connection
  // limit; the pooler multiplexes many app connections onto few DB connections.
  url        = env("DATABASE_URL")
  // Migrations need a DIRECT connection (port 5432) because they use advisory
  // locks and DDL that poolers in transaction mode don't support.
  directUrl = env("DIRECT_URL")
  // NOTE: pgvector is enabled by a raw `CREATE EXTENSION IF NOT EXISTS vector;`
  // at the top of the init migration — NOT via Prisma's postgresqlExtensions
  // feature. WHY: that feature makes Prisma manage the database's whole
  // extension list, and Supabase pre-installs several of its own (pgcrypto,
  // uuid-ossp, supabase_vault, pg_stat_statements). Prisma sees those as
  // "drift" on every migrate and demands a destructive reset.
}

model KBArticle {
  id         String     @id @default(cuid())
  title      String
  // e.g. "Network", "Hardware", "Account Access", "Software". A plain string
  // (not an enum) because helpdesk categories change often — adding one
  // shouldn't require a migration.
  category   String
  source     Source     @default(RUNBOOK)
  // visibility/ownerId are captured at upload but not yet enforced in Phase 1.
  // WHY they exist from day one: retrieval-time access control (Phase 2) is
  // this project's headline security feature, and adding it later should be a
  // WHERE clause on the search query — not a migration + backfill.
  visibility Visibility @default(INTERNAL)
  ownerId    String     @default("it-staff")
  createdAt  DateTime   @default(now())
  chunks     Chunk[]
}

model Chunk {
  id         String    @id @default(cuid())
  articleId  String
  article    KBArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  content    String
  // Prisma has no native vector type, so we declare it "Unsupported". Prisma
  // will create the column in migrations but won't let us read/write it via
  // the typed client — all embedding reads/writes go through raw SQL.
  // 1536 dims: gemini-embedding-001 natively outputs 3072, but supports
  // Matryoshka truncation to smaller sizes. We ask for 1536 because
  // (a) it matches the spec, and (b) pgvector's HNSW/IVFFlat indexes cap at
  // 2000 dims — a 3072-dim column could never be indexed for fast search.
  embedding  Unsupported("vector(1536)")?
  chunkIndex Int

  @@index([articleId])
}

// Where a KB article came from. Matters for retrieval UX (agents trust a
// runbook more than a past ticket) and for Phase 3 eval slicing.
enum Source {
  RUNBOOK
  FAQ
  PAST_TICKET
}

enum Visibility {
  INTERNAL // only IT staff can retrieve (security runbooks, escalation docs)
  PUBLIC   // any employee can retrieve (general FAQs)
}
